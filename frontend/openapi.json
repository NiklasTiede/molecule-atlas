  "info": {
    "description": "Candidate review API for small-molecule datasets.",
    "title": "Molecule Atlas API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/candidate-sets/demo": {
      "get": {
        "operationId": "get_demo_candidate_set_api_candidate_sets_demo_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CandidateSet"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Demo Candidate Set",
        "tags": [
          "candidate-sets"
        ]
      }
    },
    "/api/candidate-sets/demo/candidates/{candidate_id}/conformer": {
      "get": {
        "operationId": "get_candidate_conformer_api_candidate_sets_demo_candidates__candidate_id__conformer_get",
        "parameters": [
          {
            "in": "path",
            "name": "candidate_id",
            "required": true,
            "schema": {
              "title": "Candidate Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConformerResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Candidate not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Conformer cannot be generated"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Stored candidate data is inconsistent"
          }
        },
        "summary": "Get Candidate Conformer",
        "tags": [
          "candidate-sets"
        ]
      }
    },
    "/api/candidate-sets/demo/candidates/{candidate_id}/neighbors": {
      "get": {
        "operationId": "get_candidate_neighbors_api_candidate_sets_demo_candidates__candidate_id__neighbors_get",
        "parameters": [
          {
            "in": "path",
            "name": "candidate_id",
            "required": true,
            "schema": {
              "title": "Candidate Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SimilarityNeighbor"
                  },
                  "title": "Response Get Candidate Neighbors Api Candidate Sets Demo Candidates  Candidate Id  Neighbors Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Candidate not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Candidate Neighbors",
        "tags": [
          "candidate-sets"
        ]
      }
    },
    "/api/candidate-sets/demo/projection": {
      "get": {
        "operationId": "get_demo_projection_api_candidate_sets_demo_projection_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ProjectionPoint"
                  },
                  "title": "Response Get Demo Projection Api Candidate Sets Demo Projection Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Demo Projection",
        "tags": [
          "candidate-sets"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
