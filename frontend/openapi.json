{
  "components": {
    "schemas": {
      "CandidateSet": {
        "additionalProperties": false,
        "properties": {
          "candidates": {
            "items": {
              "discriminator": {
                "mapping": {
                  "invalid": "#/components/schemas/InvalidCandidate",
                  "valid": "#/components/schemas/ValidCandidate"
                },
                "propertyName": "status"
              },
              "oneOf": [
                {
                  "$ref": "#/components/schemas/ValidCandidate"
                },
                {
                  "$ref": "#/components/schemas/InvalidCandidate"
                }
              ]
            },
            "title": "Candidates",
            "type": "array"
          },
          "id": {
            "minLength": 1,
            "title": "Id",
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "candidates"
        ],
        "title": "CandidateSet",
        "type": "object"
      },
      "ConformerResponse": {
        "additionalProperties": false,
        "properties": {
          "candidate_id": {
            "minLength": 1,
            "title": "Candidate Id",
            "type": "string"
          },
          "mol_block": {
            "minLength": 1,
            "title": "Mol Block",
            "type": "string"
          }
        },
        "required": [
          "candidate_id",
          "mol_block"
        ],
        "title": "ConformerResponse",
        "type": "object"
      },
      "DescriptorSet": {
        "additionalProperties": false,
