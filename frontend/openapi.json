            "title": "Murcko Scaffold"
          },
          "ring_count": {
            "minimum": 0.0,
            "title": "Ring Count",
            "type": "integer"
          },
          "rotatable_bonds": {
            "minimum": 0.0,
            "title": "Rotatable Bonds",
            "type": "integer"
          },
          "tpsa": {
            "minimum": 0.0,
            "title": "Tpsa",
            "type": "number"
          }
        },
        "required": [
          "molecular_weight",
          "logp",
          "tpsa",
          "hbond_donors",
          "hbond_acceptors",
          "rotatable_bonds",
          "ring_count",
          "heavy_atom_count",
          "fraction_csp3",
          "murcko_scaffold"
        ],
        "title": "DescriptorSet",
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
