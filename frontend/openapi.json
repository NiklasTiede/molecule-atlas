          "fraction_csp3": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Fraction Csp3",
            "type": "number"
          },
          "hbond_acceptors": {
            "minimum": 0.0,
            "title": "Hbond Acceptors",
            "type": "integer"
          },
          "hbond_donors": {
            "minimum": 0.0,
            "title": "Hbond Donors",
            "type": "integer"
          },
          "heavy_atom_count": {
            "minimum": 0.0,
            "title": "Heavy Atom Count",
            "type": "integer"
          },
          "logp": {
            "title": "Logp",
            "type": "number"
          },
          "molecular_weight": {
            "minimum": 0.0,
            "title": "Molecular Weight",
            "type": "number"
          },
          "murcko_scaffold": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
